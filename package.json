{
  "name": "peuterplannen",
  "version": "1.0.0",
  "private": true,
  "description": "PeuterPlannen — Leuke uitjes voor kinderen",
  "scripts": {
    "build": "node .scripts/generate-blog-images.js && node .scripts/optimize_images.js && node .scripts/generate-og-images.js && node .scripts/sync_portal_assets.js && node .scripts/sync_all.js",
    "build:local": "PP_FIXTURES=1 node .scripts/sync_all.js",
    "dev": "npx serve -l 3000 --no-clipboard .",
    "test": "node --test .scripts/__tests__/*.test.js",
    "test:unit": "node --test .scripts/__tests__/helpers.test.js .scripts/__tests__/config.test.js",
    "test:snapshot": "node --test .scripts/__tests__/build-snapshot.test.js",
    "test:snapshot:update": "UPDATE_SNAPSHOTS=1 node --test .scripts/__tests__/build-snapshot.test.js",
    "discover": "node .scripts/discover_horeca.js",
    "pipeline:utrecht:codex": "PIPELINE_SCORE_CONCURRENCY=20 node .scripts/pipeline/run_osm_ai_codex.js --region=Utrecht --with-surroundings=true",
    "pipeline:utrecht:codex:dry": "PIPELINE_SCORE_CONCURRENCY=20 node .scripts/pipeline/run_osm_ai_codex.js --region=Utrecht --with-surroundings=true --dry-run=true --limit=20",
    "pipeline:fetch": "node .scripts/pipeline/fetch_unscored.js",
    "pipeline:write-review": "node .scripts/pipeline/write_review.js",
    "pipeline:discover-web": "node .scripts/pipeline/discover_web.js",
    "pipeline:improve": "node .scripts/pipeline/improve_locations.js",
    "deploy:supabase": "bash .scripts/deploy_supabase.sh",
    "deploy": "bash .scripts/deploy_live.sh",
    "deploy:live": "bash .scripts/deploy_live.sh",
    "deploy:wrangler": "wrangler deploy",
    "ops:trust-gaps": "node .scripts/trust/report_context_gaps.js",
    "ops:quality-tasks": "node .scripts/trust/sync_quality_tasks.js",
    "ops:seed-priority-drafts": "node .scripts/editorial/seed_priority_location_drafts.js",
    "ops:export-editorial": "node .scripts/editorial/export_editorial_pages.js",
    "ops:briefs": "python3 .scripts/ops/generate_ops_briefs.py",
    "ops:content-freshness": "node .scripts/ops/auto-refresh-content.js",
    "ops:check-calendar": "node .scripts/ops/check-editorial-calendar.js",
    "ops:seo-health": "node .scripts/ops/seo-health-check.js",
    "audit:tokens": "node .scripts/audit_design_tokens.js",
    "audit:tokens:strict": "node .scripts/audit_design_tokens.js --strict",
    "bundle": "node esbuild.config.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:update": "npx playwright test --update-snapshots",
    "test:e2e:functional": "npx playwright test tests/functional.spec.ts",
    "test:e2e:visual": "npx playwright test tests/smoke.spec.ts",
    "test:e2e:structural": "npx playwright test tests/structural.spec.ts",
    "test:a11y": "npx playwright test tests/a11y.spec.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "clean-css": "^5.3.3",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "playwright": "^1.58.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.33.2",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.4",
    "puppeteer": "^24.37.5",
    "wrangler": "^4.70.0"
  }
}
