{
  "name": "peuterplannen",
  "version": "1.0.0",
  "private": true,
  "description": "PeuterPlannen \u2014 Leuke uitjes voor kinderen",
  "scripts": {
    "build": "node .scripts/optimize_images.js && node .scripts/sync_portal_assets.js && node .scripts/sync_all.js",
    "discover": "node .scripts/discover_horeca.js",
    "pipeline:utrecht:codex": "PIPELINE_SCORE_CONCURRENCY=20 node .scripts/pipeline/run_osm_ai_codex.js --region=Utrecht --with-surroundings=true",
    "pipeline:utrecht:codex:dry": "PIPELINE_SCORE_CONCURRENCY=20 node .scripts/pipeline/run_osm_ai_codex.js --region=Utrecht --with-surroundings=true --dry-run=true --limit=20",
    "deploy:supabase": "bash .scripts/deploy_supabase.sh",
    "deploy": "bash .scripts/deploy_live.sh",
    "deploy:live": "bash .scripts/deploy_live.sh",
    "deploy:wrangler": "wrangler deploy",
    "ops:trust-gaps": "node .scripts/trust/report_context_gaps.js",
    "ops:quality-tasks": "node .scripts/trust/sync_quality_tasks.js",
    "ops:seed-priority-drafts": "node .scripts/editorial/seed_priority_location_drafts.js",
    "ops:export-editorial": "node .scripts/editorial/export_editorial_pages.js",
    "ops:briefs": "python3 .scripts/ops/generate_ops_briefs.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "clean-css": "^5.3.3",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.33.2",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "puppeteer": "^24.37.5",
    "wrangler": "^4.70.0"
  }
}
