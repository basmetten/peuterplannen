{
  "name": "peuterplannen-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/bundle-posts.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "migrate:photos": "node scripts/migrate-photos-r2.mjs",
    "migrate:photos:dry": "DRY_RUN=1 node scripts/migrate-photos-r2.mjs",
    "test:e2e": "playwright test e2e/core-flows.spec.ts",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:staging": "opennextjs-cloudflare build && wrangler deploy"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@silk-hq/components": "^0.10.1",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "@xstate/react": "^6.1.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "maplibre-gl": "^5.21.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "web-vitals": "^5.2.0",
    "xstate": "^5.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
